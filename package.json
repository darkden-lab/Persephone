{
  "name": "persephone",
  "version": "0.3.0",
  "description": "Claude Code plugin for Discord and Telegram integration",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "discord",
    "telegram",
    "plugin"
  ],
  "license": "Apache-2.0",
  "dependencies": {

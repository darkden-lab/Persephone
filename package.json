    "@modelcontextprotocol/sdk": "^1.26.0",
    "discord.js": "^14.25.1",
    "mpg123-decoder": "^1.0.3",
    "ogg-opus-decoder": "^1.7.3",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "undici": ">=6.23.0"
  }
}
